<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>март · русский · история · тренировки · проект</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#151515">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 12px;
            margin: 0;
        }

        .widget {
            max-width: 450px;
            width: 100%;
            background: #151515;
            border-radius: 40px;
            padding: 24px 20px 24px 20px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.9);
            border: 1px solid #2a2a2a;
            margin: 20px 0;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .month {
            font-size: 2rem;
            font-weight: 300;
            color: #f0f0f0;
        }
        .month span {
            font-weight: 200;
            color: #777;
            font-size: 1.4rem;
            margin-left: 5px;
        }

        .legend {
            display: flex;
            gap: 16px;
            background: #232323;
            padding: 6px 16px;
            border-radius: 40px;
            border: 1px solid #333;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .dot {
            width: 14px;
            height: 14px;
            border-radius: 5px;
        }
        .rus-dot { background: #f9d7e8; box-shadow: 0 0 8px #f9d7e880; }
        .hist-dot { background: #c0b59e; box-shadow: 0 0 8px #c0b59e80; }
        .legend-item span {
            color: #ccc;
            font-size: 0.8rem;
            font-weight: 300;
        }

        .weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            margin-bottom: 10px;
            color: #666;
            font-weight: 500;
            font-size: 0.7rem;
            letter-spacing: 0.3px;
            text-transform: uppercase;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
            margin-bottom: 20px;
        }

        .day-cell {
            background: #1f1f1f;
            aspect-ratio: 1 / 1;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 600;
            color: #c0c0c0;
            border: 1.5px solid transparent;
            box-shadow: 0 2px 6px rgba(0,0,0,0.5);
            cursor: pointer;
            transition: all 0.1s ease;
            -webkit-touch-callout: none;
            position: relative;
        }

        .day-cell.empty {
            background: #181818;
            opacity: 0.2;
            pointer-events: none;
            box-shadow: none;
        }

        .day-cell.rus {
            background: #f9d7e8;
            color: #151515;
            font-weight: 700;
            border-color: #f9d7e8;
        }

        .day-cell.hist {
            background: #c0b59e;
            color: #151515;
            font-weight: 700;
            border-color: #c0b59e;
        }

        .day-cell.workout {
            background: #1f1f1f;
            color: #c0c0c0;
            border-color: transparent;
        }

        .day-cell.workout::after {
            content: '💪';
            position: absolute;
            bottom: 2px;
            right: 2px;
            font-size: 0.7rem;
            opacity: 0.85;
            filter: brightness(1.2);
            text-shadow: 0 1px 2px rgba(0,0,0,0.7);
            pointer-events: none;
        }

        .day-cell.rus:active, .day-cell.hist:active, .day-cell.workout:active {
            transform: scale(0.96);
            opacity: 0.9;
        }

        .day-cell.selected {
            border: 3px solid white;
            box-shadow: 0 0 0 2px currentColor;
        }

        .project-block {
            margin-bottom: 20px;
        }
        
        .project-title {
            color: #aaa;
            font-size: 0.9rem;
            font-weight: 300;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            padding-left: 4px;
        }
        
        .project-scale {
            display: flex;
            gap: 6px;
            height: 60px;
        }
        
        .project-part {
            flex: 1;
            background: #1f1f1f;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s ease;
            border: 1.5px solid transparent;
            box-shadow: 0 2px 8px rgba(0,0,0,0.6);
            padding: 8px 0;
        }
        
        .project-part:active {
            transform: scale(0.96);
            background: #2a2a2a;
        }
        
        .project-part.selected {
            border: 2px solid #7a7a7a;
            background: #2a2a2a;
        }
        
        .project-dates {
            color: #888;
            font-size: 0.7rem;
            font-weight: 400;
            margin-bottom: 4px;
        }
        
        .project-name {
            color: #b0e57c;
            font-size: 0.9rem;
            font-weight: 400;
        }

        /* ПОЛЕ С ТЕМОЙ — ФИКСИРОВАННЫЙ РАЗМЕР + ПОЛЗУНОК */
        .topic-panel {
            margin-top: 10px;
            background: #1b1b1b;
            border-radius: 30px;
            border: 1px solid #2b2b2b;
            box-shadow: inset 0 2px 10px #0a0a0a;
            
            /* Фиксированная высота */
            height: 130px;
            width: 100%;
            
            /* Скролл */
            overflow-y: auto;
            padding: 18px 20px;
            
            /* Кастомный скроллбар */
            scrollbar-width: thin;
            scrollbar-color: #f9d7e8 #2a2a2a;
        }

        /* Для Chrome/Edge/Safari */
        .topic-panel::-webkit-scrollbar {
            width: 6px;
        }
        
        .topic-panel::-webkit-scrollbar-track {
            background: #2a2a2a;
            border-radius: 10px;
            margin: 8px 0;
        }
        
        .topic-panel::-webkit-scrollbar-thumb {
            background: #f9d7e8;
            border-radius: 10px;
            border: 1px solid #3a3a3a;
        }
        
        .topic-panel::-webkit-scrollbar-thumb:hover {
            background: #ffd0e0;
        }

        .panel-content {
            width: 100%;
            color: #ddd;
            font-size: 1rem;
            line-height: 1.5;
            word-break: break-word;
            min-height: 100%;
        }

        .topic-placeholder {
            color: #5a5a5a;
            font-style: italic;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .topic-placeholder::before {
            content: '📌';
            font-size: 1.2rem;
            opacity: 0.5;
        }

        .fade-topic {
            animation: fadeSlide 0.2s ease-out;
        }

        @keyframes fadeSlide {
            0% { opacity: 0; transform: translateY(5px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .topic-date {
            font-size: 0.8rem;
            color: #999;
            margin-bottom: 4px;
            font-weight: 300;
            letter-spacing: 0.3px;
        }
        
        .topic-text {
            font-size: 1.1rem;
            font-weight: 320;
            color: #eee;
            line-height: 1.5;
        }

        .footer {
            margin-top: 16px;
            text-align: right;
            color: #3d3d3d;
            font-size: 0.65rem;
            border-top: 1px solid #252525;
            padding-top: 16px;
        }

        @supports (padding: max(0px)) {
            .widget {
                padding-left: max(20px, env(safe-area-inset-left));
                padding-right: max(20px, env(safe-area-inset-right));
            }
        }
    </style>
</head>
<body>
    <div class="widget">
        <div class="header">
            <div class="month">март <span>2026</span></div>
            <div class="legend">
                <div class="legend-item"><div class="dot rus-dot"></div><span>рус</span></div>
                <div class="legend-item"><div class="dot hist-dot"></div><span>ист</span></div>
            </div>
        </div>

        <div class="weekdays">
            <div>пн</div><div>вт</div><div>ср</div><div>чт</div><div>пт</div><div>сб</div><div>вс</div>
        </div>

        <div class="calendar-grid" id="calendarGrid">
            <!-- пустые февральские -->
            <div class="day-cell empty"></div><div class="day-cell empty"></div><div class="day-cell empty"></div>
            <div class="day-cell empty"></div><div class="day-cell empty"></div><div class="day-cell empty"></div>
            <!-- 1 -->
            <div class="day-cell">1</div>

            <!-- 2 рус -->
            <div class="day-cell rus" data-date="02.03" data-topic="лексика и морфология, синтаксические нормы · паронимы, плеоназмы, тавтологии">2</div>
            <!-- 3 ист -->
            <div class="day-cell hist" data-date="03.03" data-topic="Ржев и Харьков · Битва за Кавказ · Коренной перелом: Сталинград">3</div>
            <!-- 4 тренировка -->
            <div class="day-cell workout" data-date="04.03" data-topic="💪 ТРЕНИРОВКА: жим, тяга, плечи">4</div>
            <!-- 5 рус -->
            <div class="day-cell rus" data-date="05.03" data-topic="паронимы, ударения, прич. и дееприч. обороты, числительные, формы глаголов, однородные">5</div>
            <!-- 6 тренировка -->
            <div class="day-cell workout" data-date="06.03" data-topic="💪 ТРЕНИРОВКА: ноги, бицепс, трицепс">6</div>
            <!-- 7 ист -->
            <div class="day-cell hist" data-date="07.03" data-topic="Операция 'Искра' · Курск · Днепр">7</div>
            <!-- 8 -->
            <div class="day-cell">8</div>

            <!-- 9 рус -->
            <div class="day-cell rus" data-date="09.03" data-topic="фразеология и орфоэпия · числительные, формы глаголов, косвенная речь">9</div>
            <!-- 10 ист -->
            <div class="day-cell hist" data-date="10.03" data-topic="1944 год · 'десять сталинских ударов'">10</div>
            <!-- 11 тренировка -->
            <div class="day-cell workout" data-date="11.03" data-topic="💪 ТРЕНИРОВКА: жим, тяга, плечи">11</div>
            <!-- 12 рус -->
            <div class="day-cell rus" data-date="12.03" data-topic="корни и суффиксы, приставки · чередования, пре/при, з/с">12</div>
            <!-- 13 тренировка -->
            <div class="day-cell workout" data-date="13.03" data-topic="💪 ТРЕНИРОВКА: ноги, бицепс, трицепс">13</div>
            <!-- 14 ист -->
            <div class="day-cell hist" data-date="14.03" data-topic="Дорога на Берлин · Победа в ВОВ · Окончание Второй мировой">14</div>
            <!-- 15 -->
            <div class="day-cell">15</div>

            <!-- 16 рус -->
            <div class="day-cell rus" data-date="16.03" data-topic="Н/НН · суффиксы глаголов, прилагательных · нн в причастиях">16</div>
            <!-- 17 ист -->
            <div class="day-cell hist" data-date="17.03" data-topic="Тыл — фронт · Дипломатия · Ленд-лиз">17</div>
            <!-- 18 тренировка -->
            <div class="day-cell workout" data-date="18.03" data-topic="💪 ТРЕНИРОВКА: жим, тяга, плечи">18</div>
            <!-- 19 рус -->
            <div class="day-cell rus" data-date="19.03" data-topic="раздельно, слитно, дефис · не с частями речи, предлоги, частицы, пол-">19</div>
            <!-- 20 тренировка -->
            <div class="day-cell workout" data-date="20.03" data-topic="💪 ТРЕНИРОВКА: ноги, бицепс, трицепс">20</div>
            <!-- 21 ист -->
            <div class="day-cell hist" data-date="21.03" data-topic="Жизнь в оккупации · Партизанское движение">21</div>
            <!-- 22 -->
            <div class="day-cell">22</div>

            <!-- 23 рус -->
            <div class="day-cell rus" data-date="23.03" data-topic="пунктуация, запятые при оборотах, вводные, стык союзов, тире">23</div>
            <!-- 24 ист -->
            <div class="day-cell hist" data-date="24.03" data-topic="Культура ВОВ · Повторение · Практика">24</div>
            <!-- 25 тренировка -->
            <div class="day-cell workout" data-date="25.03" data-topic="💪 ТРЕНИРОВКА: жим, тяга, плечи">25</div>
            <!-- 26 рус -->
            <div class="day-cell rus" data-date="26.03" data-topic="текст, тропы · структура сочинения, типы речи, метафоры, эпитеты, парцелляция">26</div>
            <!-- 27 тренировка -->
            <div class="day-cell workout" data-date="27.03" data-topic="💪 ТРЕНИРОВКА: ноги, бицепс, трицепс">27</div>
            <!-- 28 рус -->
            <div class="day-cell rus" data-date="28.03" data-topic="сочинение #1: аргументация, частые ошибки, практика">28</div>
            <!-- 29 -->
            <div class="day-cell">29</div>

            <!-- 30 рус -->
            <div class="day-cell rus" data-date="30.03" data-topic="сочинение #2: продолжение практики, работа над ошибками">30</div>
            <!-- 31 -->
            <div class="day-cell">31</div>

            <!-- пустые апрельские -->
            <div class="day-cell empty"></div><div class="day-cell empty"></div><div class="day-cell empty"></div>
            <div class="day-cell empty"></div><div class="day-cell empty"></div>
        </div>

        <div class="project-block">
            <div class="project-title">📋 ПРОЕКТ</div>
            <div class="project-scale">
                <div class="project-part" data-phase="1" data-topic="ПОДГОТОВКА СТАТЬИ · сбор материалов, написание черновика, работа с источниками">
                    <div class="project-dates">01 — 10</div>
                    <div class="project-name">подготовка</div>
                </div>
                <div class="project-part" data-phase="2" data-topic="ПРОВЕДЕНИЕ ОПРОСА · анкетирование, интервью, сбор данных, анализ результатов">
                    <div class="project-dates">11 — 19</div>
                    <div class="project-name">опрос</div>
                </div>
                <div class="project-part" data-phase="3" data-topic="ОФОРМЛЕНИЕ ПРОЕКТА · визуализация, вёрстка, финальный отчёт, презентация">
                    <div class="project-dates">20 — 31</div>
                    <div class="project-name">оформление</div>
                </div>
            </div>
        </div>

        <!-- ПОЛЕ С ТЕМОЙ: фиксированный размер + ползунок -->
        <div class="topic-panel" id="topicPanel">
            <div class="panel-content fade-topic" id="panelContent">
                <div class="topic-placeholder">нажми на урок, тренировку или этап проекта</div>
            </div>
        </div>

        <div class="footer">русский · история · 💪 ср/пт · 📋 проект</div>
    </div>

    <script>
        (function() {
            const cells = document.querySelectorAll('.day-cell.rus, .day-cell.hist, .day-cell.workout');
            const projectParts = document.querySelectorAll('.project-part');
            const panelContent = document.getElementById('panelContent');
            
            function clearSelected() {
                cells.forEach(c => c.classList.remove('selected'));
                projectParts.forEach(p => p.classList.remove('selected'));
            }

            function showTopic(content) {
                panelContent.innerHTML = content;
                panelContent.style.animation = 'none';
                panelContent.offsetHeight;
                panelContent.style.animation = 'fadeSlide 0.2s ease-out';
            }

            function showPlaceholder() {
                panelContent.innerHTML = '<div class="topic-placeholder">нажми на урок, тренировку или этап проекта</div>';
            }

            // клик по дням календаря
            cells.forEach(cell => {
                cell.addEventListener('click', function(e) {
                    e.stopPropagation();
                    clearSelected();
                    this.classList.add('selected');
                    
                    const date = this.getAttribute('data-date') || '';
                    const topic = this.getAttribute('data-topic') || 'тема';
                    
                    let icon = '📌';
                    if (this.classList.contains('rus')) icon = '📖';
                    else if (this.classList.contains('hist')) icon = '⚔️';
                    else if (this.classList.contains('workout')) icon = '💪';
                    
                    const html = `
                        <div class="topic-date">${icon} ${date}</div>
                        <div class="topic-text">${topic}</div>
                    `;
                    showTopic(html);
                });
            });

            // клик по этапам проекта
            projectParts.forEach(part => {
                part.addEventListener('click', function(e) {
                    e.stopPropagation();
                    clearSelected();
                    this.classList.add('selected');
                    
                    const phase = this.getAttribute('data-phase');
                    const dates = this.querySelector('.project-dates').textContent;
                    const name = this.querySelector('.project-name').textContent;
                    const topic = this.getAttribute('data-topic') || 'этап проекта';
                    
                    let icon = '📋';
                    
                    const html = `
                        <div class="topic-date">${icon} этап ${phase} · ${dates}</div>
                        <div class="topic-text">${topic}</div>
                    `;
                    showTopic(html);
                });
            });

            // обычные дни сбрасывают выделение
            document.querySelectorAll('.day-cell:not(.rus):not(.hist):not(.workout):not(.empty)').forEach(day => {
                day.addEventListener('click', function() {
                    clearSelected();
                    showPlaceholder();
                });
            });

            showPlaceholder();
        })();
    </script>
</body>
</html>
